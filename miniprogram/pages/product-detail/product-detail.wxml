<view class="pd-nav" style="{{navStyle}}">
  <view class="pd-nav-back" style="{{navSideStyle}}" catchtap="onBack">
    <view class="pd-nav-back-arrow"></view>
  </view>
  <text class="pd-nav-title">{{product&&product.name?product.name:'产品详情'}}</text>
  <view class="pd-nav-placeholder" style="{{navSideStyle}}"></view>
</view>

<view class="pd-page">
  <app-loading wx:if="{{loading}}" text="正在读取产品详情"></app-loading>

  <error-state
    wx:elif="{{error}}"
    title="{{errorTitle}}"
    message="{{error}}"
    showRetry="{{canRetry}}"
    bind:retry="handleRetry"
  ></error-state>

  <block wx:elif="{{loaded && product && warehouseProduct}}">
    <view class="pd-hero">
      <view
        class="pd-cover {{warehouseProduct.stockStatus==='out'?'pd-cover--out':''}} {{warehouseProduct.stockStatus==='low'?'pd-cover--low':''}}"
        style="background:{{product.cover.background}}"
      >
        <image wx:if="{{product.cover.type==='image'}}" class="pd-cover-image" src="{{product.cover.fileId}}" mode="aspectFill" binderror="onCoverImageError"></image>
        <text wx:else class="{{product.cover.type==='emoji'?'pd-cover-emoji':'pd-cover-text'}}">{{product.cover.content}}</text>
      </view>
      <view class="pd-hero-info">
        <text class="pd-hero-name">{{product.name}}</text>
        <view class="pd-hero-meta">
          <text class="pd-hero-code">{{product.productCode||'无编号'}}</text>
          <view class="pd-hero-category">{{product.category}}</view>
          <view wx:if="{{product.brand}}" class="pd-hero-brand">{{product.brand}}</view>
        </view>
      </view>
    </view>

    <view class="pd-stock-card {{warehouseProduct.stockStatus==='out'?'pd-stock-card--out':''}} {{warehouseProduct.stockStatus==='low'?'pd-stock-card--low':''}}">
      <view class="pd-stock-left">
        <text class="pd-stock-label">{{stockLabel}}</text>
        <view class="pd-stock-value-row">
          <text class="pd-stock-value {{warehouseProduct.stockStatus==='out'?'text--danger':''}} {{warehouseProduct.stockStatus==='low'?'text--warning':''}}">{{warehouseProduct.stockText}}</text>
          <text class="pd-stock-unit">{{product.unit}}</text>
        </view>
        <text class="pd-stock-sub">{{stockSub}}</text>
      </view>
      <view class="pd-stock-right">
        <view wx:if="{{warehouseProduct.stockStatus==='out'}}" class="pd-status-badge pd-status-badge--out">已缺货</view>
        <view wx:elif="{{warehouseProduct.stockStatus==='low'}}" class="pd-status-badge pd-status-badge--low">库存偏低</view>
        <view wx:elif="{{warehouseProduct.stockStatus==='normal'}}" class="pd-status-badge pd-status-badge--normal">库存正常</view>
        <view wx:else class="pd-status-badge pd-status-badge--unknown">状态未知</view>
      </view>
    </view>

    <view class="pd-section">
      <text class="pd-section-title">产品介绍</text>
      <view wx:if="{{product.description}}" class="pd-desc-card">
        <text class="pd-desc-text {{!descExpanded?'pd-desc-text--clamped':''}}">{{product.description}}</text>
        <text wx:if="{{descNeedsExpand}}" class="pd-desc-toggle" catchtap="toggleDesc">{{descExpanded?'收起':'展开全部'}}</text>
      </view>
      <view wx:else class="pd-desc-empty">未填写产品介绍</view>
    </view>

    <view class="pd-section">
      <text class="pd-section-title">基本信息</text>
      <view class="pd-info-card">
        <view class="pd-info-row">
          <text class="pd-info-key">产品编号</text>
          <text class="pd-info-val">{{product.productCode||'未填写'}}</text>
        </view>
        <view class="pd-info-row">
          <text class="pd-info-key">单位</text>
          <text class="pd-info-val">{{product.unit||'未填写'}}</text>
        </view>
        <view class="pd-info-row">
          <text class="pd-info-key">规格</text>
          <text class="pd-info-val">{{product.specification||'未填写'}}</text>
        </view>
        <view class="pd-info-row">
          <text class="pd-info-key">品牌</text>
          <text class="pd-info-val">{{product.brand||'未填写'}}</text>
        </view>
        <view class="pd-info-row">
          <text class="pd-info-key">分类</text>
          <text class="pd-info-val">{{product.category}}</text>
        </view>
        <view class="pd-info-row">
          <text class="pd-info-key">最低库存</text>
          <text class="pd-info-val">{{warehouseProduct.minStockText}}{{warehouseProduct.minStock===null?'':product.unit}}</text>
        </view>
        <view class="pd-info-row">
          <text class="pd-info-key">产品创建时间</text>
          <text class="pd-info-val">{{product.createdAtText}}</text>
        </view>
        <view class="pd-info-row">
          <text class="pd-info-key">库存更新时间</text>
          <text class="pd-info-val">{{warehouseProduct.updatedAtText}}</text>
        </view>
      </view>
    </view>

    <view class="pd-section">
      <text class="pd-section-title">库存记录</text>
      <view class="pd-records-empty">真实库存流水将在后续阶段接入</view>
    </view>

    <view class="pd-bottom-spacer"></view>
  </block>

  <error-state
    wx:else
    title="产品不可用"
    message="产品不存在或已被移除"
    showRetry="{{false}}"
  ></error-state>
</view>

<view wx:if="{{loaded && product && !error && (permissions.canOperateStock||permissions.canEdit||permissions.canRemove)}}" class="pd-action-bar">
  <view wx:if="{{permissions.canOperateStock}}" class="pd-action-btn pd-action-btn--primary" catchtap="onInbound">入库</view>
  <view wx:if="{{permissions.canOperateStock}}" class="pd-action-btn pd-action-btn--outline" catchtap="onOutbound">出库</view>
  <view wx:if="{{permissions.canEdit||permissions.canRemove}}" class="pd-action-btn pd-action-btn--outline {{removing?'pd-action-btn--disabled':''}}" catchtap="onMore">{{removing?'处理中':'更多'}}</view>
</view>
