<view class="records-page">
  <view class="records-header">
    <view>
      <text class="records-title">库存记录</text>
      <text class="records-subtitle">查看团队的入库、出库与库存调整</text>
    </view>
    <view class="records-summary">
      <view class="summary-item"><text class="summary-value">{{summary.today}}</text><text class="summary-label">今日</text></view>
      <view class="summary-divider"></view>
      <view class="summary-item"><text class="summary-value">{{summary.week}}</text><text class="summary-label">本周</text></view>
    </view>
  </view>

  <view class="records-search">
    <view class="search-icon"></view>
    <input class="search-input" value="{{searchText}}" placeholder="搜索产品名称、编号或操作人" bindinput="onSearchInput" confirm-type="search"/>
    <view wx:if="{{searchText}}" class="search-clear" catchtap="onSearchClear">×</view>
  </view>

  <view class="records-tools">
    <scroll-view class="type-scroll" scroll-x enhanced show-scrollbar="{{false}}">
      <view class="type-row">
        <view wx:for="{{typeOptions}}" wx:key="value" class="type-chip {{activeType===item.value?'type-chip--active':''}}" data-value="{{item.value}}" catchtap="onTypeTap">{{item.label}}</view>
      </view>
    </scroll-view>
    <view class="filter-button {{filterTags.length?'filter-button--active':''}}" catchtap="openFilter">
      <view class="filter-icon"><view></view><view></view><view></view></view>
      <text>筛选</text>
      <view wx:if="{{filterTags.length}}" class="filter-count">{{filterTags.length}}</view>
    </view>
  </view>

  <view wx:if="{{filterTags.length}}" class="filter-tags">
    <view wx:for="{{filterTags}}" wx:key="key" class="filter-tag" data-key="{{item.key}}" catchtap="removeFilterTag">
      <text>{{item.label}}</text><text class="filter-tag-close">×</text>
    </view>
  </view>

  <view wx:if="{{resultCount}}" class="records-result">{{resultCount}} 条记录</view>

  <view wx:if="{{resultCount}}" class="record-groups">
    <view wx:for="{{groups}}" wx:key="key" class="record-group">
      <view class="group-heading"><view class="group-dot"></view><text>{{item.title}}</text><view class="group-line"></view></view>
      <view wx:for="{{item.records}}" wx:for-item="record" wx:key="id" class="record-card" data-id="{{record.id}}" bindtap="openDetail">
        <view class="record-card-head">
          <view class="record-type record-type--{{record.typeClass}}"><view class="record-type-mark"></view><text>{{record.typeLabel}}</text></view>
          <view class="record-delta record-delta--{{record.typeClass}}"><text>{{record.deltaText}}</text><text class="record-unit"> {{record.unit}}</text></view>
        </view>
        <view class="record-main">
          <view class="record-product"><text class="record-name">{{record.productName}}</text><text class="record-code">{{record.productCode}}</text></view>
          <view class="record-stock"><text>{{record.stockBeforeText}}</text><text class="stock-arrow">→</text><text class="stock-after">{{record.stockAfterText}}</text><text class="record-unit"> {{record.unit}}</text></view>
        </view>
        <view class="record-meta"><text>{{record.operatorName}}</text><text class="meta-dot">·</text><text>{{record.timeText}}</text></view>
        <text wx:if="{{record.hasRemark}}" class="record-remark">{{record.remarkText}}</text>
      </view>
    </view>
  </view>

  <view wx:else class="records-empty">
    <empty-state title="{{hasAnyRecords?'没有符合条件的记录':'暂无库存记录'}}" description="{{hasAnyRecords?'尝试修改搜索关键词或筛选条件':'完成第一次入库、出库或库存调整后，记录会显示在这里'}}"></empty-state>
    <view wx:if="{{hasAnyRecords}}" class="empty-action" catchtap="clearAllFilters">清除筛选</view>
  </view>
</view>

<view wx:if="{{filterOpen}}" class="sheet-mask" catchtap="closeFilter" catchtouchmove="stopPropagation">
  <view class="bottom-sheet filter-sheet" catchtap="stopPropagation">
    <view class="sheet-handle"></view>
    <view class="sheet-header"><text class="sheet-title">筛选记录</text><view class="sheet-close" catchtap="closeFilter">×</view></view>
    <scroll-view class="filter-content" scroll-y>
      <view class="filter-section">
        <text class="filter-section-title">产品</text>
        <view class="option-list">
          <view class="option-chip {{tempProductId===''?'option-chip--active':''}}" data-value="" catchtap="onTempProductTap">全部产品</view>
          <view wx:for="{{productOptions}}" wx:key="value" class="option-chip option-chip--product {{tempProductId===item.value?'option-chip--active':''}}" data-value="{{item.value}}" catchtap="onTempProductTap"><text>{{item.label}}</text><text class="option-sub">{{item.subLabel}}</text></view>
        </view>
      </view>
      <view class="filter-section">
        <text class="filter-section-title">操作人</text>
        <view class="option-list">
          <view class="option-chip {{tempOperatorId===''?'option-chip--active':''}}" data-value="" catchtap="onTempOperatorTap">全部操作人</view>
          <view wx:for="{{operatorOptions}}" wx:key="value" class="option-chip {{tempOperatorId===item.value?'option-chip--active':''}}" data-value="{{item.value}}" catchtap="onTempOperatorTap">{{item.label}}</view>
        </view>
      </view>
      <view class="filter-section">
        <text class="filter-section-title">时间范围</text>
        <view class="option-list">
          <view wx:for="{{dateOptions}}" wx:key="value" class="option-chip {{tempDateRange===item.value?'option-chip--active':''}}" data-value="{{item.value}}" catchtap="onTempDateTap">{{item.label}}</view>
        </view>
      </view>
    </scroll-view>
    <view class="sheet-actions"><view class="sheet-action sheet-action--secondary" catchtap="resetTempFilters">重置</view><view class="sheet-action sheet-action--primary" catchtap="applyFilters">确定</view></view>
  </view>
</view>

<view wx:if="{{detailOpen}}" class="sheet-mask" catchtap="closeDetail" catchtouchmove="stopPropagation">
  <view class="bottom-sheet detail-sheet" catchtap="stopPropagation">
    <view class="sheet-handle"></view>
    <view class="sheet-header"><text class="sheet-title">记录详情</text><view class="sheet-close" catchtap="closeDetail">×</view></view>
    <scroll-view class="detail-content" scroll-y>
      <view class="detail-hero record-type--{{selectedRecord.typeClass}}"><view class="detail-type-mark"></view><view><text class="detail-type">{{selectedRecord.typeLabel}}</text><text class="detail-product">{{selectedRecord.productName}}</text></view><text class="detail-delta">{{selectedRecord.deltaText}} {{selectedRecord.unit}}</text></view>
      <view class="detail-rows">
        <view wx:for="{{detailRows}}" wx:key="label" class="detail-row"><text class="detail-label">{{item.label}}</text><text class="detail-value {{item.accent?'detail-value--accent':''}}">{{item.value}}</text></view>
      </view>
    </scroll-view>
    <view class="sheet-actions detail-actions"><view wx:if="{{selectedHasProduct}}" class="sheet-action sheet-action--primary" catchtap="viewProduct">查看产品</view><view wx:else class="sheet-action sheet-action--secondary" catchtap="closeDetail">关闭</view></view>
  </view>
</view>
