<view class="records-page">
  <view class="records-header">
    <view>
      <text class="records-title">库存流水</text>
      <text class="records-subtitle">查看当前仓库全部商品的真实库存记录</text>
    </view>
    <view class="records-summary">
      <view class="summary-item"><text class="summary-value">{{summary.today}}</text><text class="summary-label">今日</text></view>
      <view class="summary-divider"></view>
      <view class="summary-item"><text class="summary-value">{{summary.loaded}}</text><text class="summary-label">已载入</text></view>
    </view>
  </view>

  <view class="records-tools">
    <scroll-view class="type-scroll" scroll-x enhanced show-scrollbar="{{false}}">
      <view class="type-row">
        <view wx:for="{{typeOptions}}" wx:key="value" class="type-chip {{activeType===item.value?'type-chip--active':''}}" data-value="{{item.value}}" catchtap="onTypeTap">{{item.label}}</view>
      </view>
    </scroll-view>
  </view>

  <view class="records-tools records-tools--date">
    <scroll-view class="type-scroll" scroll-x enhanced show-scrollbar="{{false}}">
      <view class="type-row">
        <view wx:for="{{dateOptions}}" wx:key="value" class="type-chip date-chip {{activeDateRange===item.value?'type-chip--active':''}}" data-value="{{item.value}}" catchtap="onDateTap">{{item.label}}</view>
      </view>
    </scroll-view>
  </view>

  <view wx:if="{{loading}}" class="records-loading">
    <view class="loading-spinner"></view>
    <text>正在加载库存流水</text>
  </view>

  <view wx:elif="{{error}}" class="records-error">
    <empty-state title="库存流水加载失败" description="{{error}}"></empty-state>
    <view class="empty-action" catchtap="handleRetry">重新加载</view>
  </view>

  <view wx:elif="{{records.length}}" class="record-groups">
    <view wx:for="{{groups}}" wx:key="key" class="record-group">
      <view class="group-heading"><view class="group-dot"></view><text>{{item.title}}</text><view class="group-line"></view></view>
      <view wx:for="{{item.records}}" wx:for-item="record" wx:key="id" class="record-card" data-id="{{record.id}}" bindtap="onRecordTap">
        <view class="record-card-head">
          <view class="record-type record-type--{{record.typeClass}}"><view class="record-type-mark"></view><text>{{record.typeLabel}}</text></view>
          <view class="record-delta record-delta--{{record.typeClass}}"><text>{{record.deltaText}}</text><text class="record-unit"> {{record.unit}}</text></view>
        </view>
        <view class="record-main">
          <view class="record-cover cover-{{record.cover.type}}" style="background: {{record.cover.background}}">
            <image wx:if="{{record.cover.showImage}}" class="record-cover-image" src="{{record.cover.imageUrl}}" mode="aspectFill" data-id="{{record.id}}" binderror="onCoverImageError"></image>
            <text wx:else>{{record.cover.content}}</text>
          </view>
          <view class="record-product">
            <text class="record-name">{{record.productName}}</text>
            <text class="record-code">{{record.productCodeText}}</text>
          </view>
          <view class="record-stock"><text>{{record.beforeStock}}</text><text class="stock-arrow">→</text><text class="stock-after">{{record.afterStock}}</text><text class="record-unit"> {{record.unit}}</text></view>
        </view>
        <view class="record-meta"><text>{{record.createdAtText}}</text><text class="meta-dot">·</text><text>{{record.operatorText}}</text></view>
        <view class="record-remark">
          <text>原因：{{record.reasonText}}</text>
          <text>单据：{{record.referenceText}}</text>
        </view>
      </view>
    </view>
    <view wx:if="{{loadingMore}}" class="load-more"><view class="loading-spinner loading-spinner--small"></view><text>加载更多</text></view>
    <view wx:elif="{{hasMore}}" class="load-more load-more--button" catchtap="loadMore">加载更多</view>
    <view wx:else class="load-more load-more--end">没有更多流水</view>
  </view>

  <view wx:else class="records-empty">
    <empty-state title="暂无库存流水" description="完成新增商品、入库、出库或盘点后，记录会显示在这里"></empty-state>
  </view>
</view>
