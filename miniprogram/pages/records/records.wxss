.records-page { min-height: 100vh; padding: 28rpx 28rpx calc(48rpx + env(safe-area-inset-bottom)); background: #F7F8F7; box-sizing: border-box; overflow-x: hidden; }
.records-header { display: flex; align-items: flex-end; justify-content: space-between; margin-bottom: 26rpx; }
.records-title, .records-subtitle { display: block; }
.records-title { color: #171917; font-size: 40rpx; font-weight: 700; line-height: 1.25; }
.records-subtitle { margin-top: 8rpx; color: #747A76; font-size: 23rpx; }
.records-summary { display: flex; align-items: center; padding: 14rpx 18rpx; background: #FFFFFF; border: 1rpx solid #E7EBE8; border-radius: 16rpx; }
.summary-item { min-width: 58rpx; text-align: center; }
.summary-value, .summary-label { display: block; }
.summary-value { color: #078B4B; font-size: 28rpx; font-weight: 700; line-height: 1; }
.summary-label { margin-top: 6rpx; color: #747A76; font-size: 19rpx; }
.summary-divider { width: 1rpx; height: 42rpx; margin: 0 14rpx; background: #E7EBE8; }
.records-search { display: flex; align-items: center; height: 80rpx; padding: 0 22rpx; background: #FFFFFF; border: 2rpx solid #E7EBE8; border-radius: 16rpx; box-sizing: border-box; }
.search-icon { width: 24rpx; height: 24rpx; border: 3rpx solid #747A76; border-radius: 50%; position: relative; flex-shrink: 0; }
.search-icon::after { content: ''; position: absolute; right: -9rpx; bottom: -6rpx; width: 12rpx; height: 3rpx; background: #747A76; transform: rotate(45deg); border-radius: 2rpx; }
.search-input { flex: 1; height: 76rpx; margin-left: 20rpx; color: #171917; font-size: 26rpx; }
.search-clear, .sheet-close { display: flex; align-items: center; justify-content: center; color: #747A76; }
.search-clear { width: 44rpx; height: 44rpx; font-size: 36rpx; }
.records-tools { display: flex; align-items: center; margin-top: 20rpx; gap: 16rpx; }
.type-scroll { flex: 1; min-width: 0; white-space: nowrap; }
.type-row { display: inline-flex; gap: 12rpx; }
.type-chip { display: flex; align-items: center; justify-content: center; height: 58rpx; min-width: 88rpx; padding: 0 18rpx; border-radius: 12rpx; background: #FFFFFF; border: 1rpx solid #E7EBE8; color: #747A76; font-size: 24rpx; box-sizing: border-box; }
.type-chip--active { border-color: #078B4B; background: #EAF6EF; color: #06713E; font-weight: 600; }
.filter-button { flex-shrink: 0; display: flex; align-items: center; justify-content: center; height: 58rpx; padding: 0 18rpx; gap: 9rpx; border-radius: 12rpx; background: #FFFFFF; border: 1rpx solid #E7EBE8; color: #171917; font-size: 24rpx; }
.filter-button--active { border-color: #078B4B; color: #078B4B; }
.filter-icon { width: 24rpx; }
.filter-icon view { height: 2rpx; margin: 4rpx 0; background: currentColor; }
.filter-icon view:nth-child(2) { width: 17rpx; }
.filter-icon view:nth-child(3) { width: 10rpx; }
.filter-count { display: flex; align-items: center; justify-content: center; min-width: 28rpx; height: 28rpx; padding: 0 4rpx; border-radius: 14rpx; background: #078B4B; color: #FFFFFF; font-size: 18rpx; box-sizing: border-box; }
.filter-tags { display: flex; flex-wrap: wrap; gap: 10rpx; margin-top: 18rpx; }
.filter-tag { display: flex; align-items: center; max-width: 100%; height: 48rpx; padding: 0 14rpx; border-radius: 10rpx; background: #EAF6EF; color: #06713E; font-size: 21rpx; box-sizing: border-box; }
.filter-tag text:first-child { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.filter-tag-close { flex-shrink: 0; margin-left: 10rpx; font-size: 29rpx; }
.records-result { margin: 24rpx 2rpx 12rpx; color: #747A76; font-size: 21rpx; }
.record-group { margin-bottom: 28rpx; }
.group-heading { display: flex; align-items: center; height: 54rpx; color: #4D554F; font-size: 24rpx; font-weight: 600; }
.group-dot { width: 10rpx; height: 10rpx; margin-right: 12rpx; border-radius: 50%; background: #078B4B; }
.group-line { flex: 1; height: 1rpx; margin-left: 16rpx; background: #E7EBE8; }
.record-card { margin-bottom: 16rpx; padding: 22rpx; background: #FFFFFF; border: 1rpx solid #E7EBE8; border-radius: 16rpx; box-sizing: border-box; }
.record-card:active { background: #F4F8F5; }
.record-card-head, .record-main, .record-meta, .record-type, .record-delta, .record-stock { display: flex; align-items: center; }
.record-card-head, .record-main { justify-content: space-between; gap: 18rpx; }
.record-type { gap: 9rpx; padding: 5rpx 12rpx; border-radius: 8rpx; font-size: 21rpx; font-weight: 600; }
.record-type-mark, .detail-type-mark { flex-shrink: 0; border-radius: 50%; background: currentColor; }
.record-type-mark { width: 10rpx; height: 10rpx; }
.record-type--inbound, .record-type--adjustment-up { background: #EAF6EF; color: #078B4B; }
.record-type--outbound { background: #EEF2F4; color: #52646D; }
.record-type--adjustment, .record-type--adjustment-down, .record-type--adjustment-zero { background: #FFF6E8; color: #C8780F; }
.record-type--initial { background: #F1F2F1; color: #747A76; }
.record-type--unknown { background: #FDF2F2; color: #D94A45; }
.record-delta { flex-shrink: 0; color: #078B4B; font-size: 30rpx; font-weight: 700; }
.record-delta--outbound { color: #52646D; }
.record-delta--adjustment, .record-delta--adjustment-down, .record-delta--adjustment-zero { color: #E59A23; }
.record-delta--unknown { color: #D94A45; }
.record-unit { font-size: 20rpx; font-weight: 400; color: #747A76; white-space: nowrap; }
.record-main { margin-top: 17rpx; align-items: flex-end; }
.record-product { flex: 1; min-width: 0; }
.record-name, .record-code { display: block; }
.record-name { overflow: hidden; color: #171917; font-size: 28rpx; font-weight: 600; text-overflow: ellipsis; white-space: nowrap; }
.record-code { margin-top: 5rpx; color: #747A76; font-size: 21rpx; }
.record-stock { flex-shrink: 0; color: #747A76; font-size: 24rpx; white-space: nowrap; }
.stock-arrow { margin: 0 8rpx; color: #B6BAB7; }
.stock-after { color: #171917; font-weight: 700; }
.record-meta { margin-top: 16rpx; color: #747A76; font-size: 21rpx; }
.meta-dot { margin: 0 9rpx; }
.record-remark { display: -webkit-box; margin-top: 12rpx; padding-top: 12rpx; border-top: 1rpx solid #F1F3F1; overflow: hidden; color: #59615C; font-size: 22rpx; line-height: 1.5; -webkit-box-orient: vertical; -webkit-line-clamp: 2; }
.records-empty { padding-top: 46rpx; text-align: center; }
.empty-action { display: inline-flex; align-items: center; justify-content: center; height: 72rpx; margin-top: -42rpx; padding: 0 32rpx; border: 2rpx solid #078B4B; border-radius: 14rpx; color: #078B4B; font-size: 25rpx; }
.sheet-mask { position: fixed; z-index: 200; top: 0; right: 0; bottom: 0; left: 0; display: flex; align-items: flex-end; background: rgba(23, 25, 23, 0.46); }
.bottom-sheet { width: 100%; max-height: 86vh; padding-bottom: env(safe-area-inset-bottom); border-radius: 24rpx 24rpx 0 0; background: #FFFFFF; box-sizing: border-box; overflow: hidden; }
.sheet-handle { width: 72rpx; height: 7rpx; margin: 14rpx auto 4rpx; border-radius: 4rpx; background: #D8DCD8; }
.sheet-header { display: flex; align-items: center; justify-content: space-between; height: 82rpx; padding: 0 28rpx; border-bottom: 1rpx solid #E7EBE8; }
.sheet-title { color: #171917; font-size: 30rpx; font-weight: 700; }
.sheet-close { width: 56rpx; height: 56rpx; border-radius: 50%; background: #F2F4F2; font-size: 38rpx; }
.filter-content { max-height: 58vh; padding: 0 28rpx; box-sizing: border-box; }
.filter-section { padding: 24rpx 0 6rpx; }
.filter-section-title { display: block; margin-bottom: 16rpx; color: #171917; font-size: 25rpx; font-weight: 600; }
.option-list { display: flex; flex-wrap: wrap; gap: 12rpx; }
.option-chip { display: flex; align-items: center; justify-content: center; min-height: 58rpx; padding: 9rpx 18rpx; border: 1rpx solid #E7EBE8; border-radius: 12rpx; background: #F7F8F7; color: #59615C; font-size: 22rpx; box-sizing: border-box; }
.option-chip--product { flex-direction: column; align-items: flex-start; max-width: 320rpx; }
.option-chip--product text:first-child { max-width: 270rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.option-sub { margin-top: 3rpx; color: #8B918D; font-size: 18rpx; }
.option-chip--active { border-color: #078B4B; background: #EAF6EF; color: #06713E; }
.sheet-actions { display: flex; gap: 16rpx; padding: 18rpx 28rpx; border-top: 1rpx solid #E7EBE8; background: #FFFFFF; }
.sheet-action { display: flex; flex: 1; align-items: center; justify-content: center; height: 82rpx; border-radius: 14rpx; font-size: 27rpx; font-weight: 600; }
.sheet-action--secondary { border: 2rpx solid #DDE2DE; color: #59615C; box-sizing: border-box; }
.sheet-action--primary { background: #078B4B; color: #FFFFFF; }
.detail-content { max-height: 62vh; padding: 0 28rpx; box-sizing: border-box; }
.detail-hero { display: flex; align-items: center; margin: 22rpx 0; padding: 22rpx; border-radius: 14rpx; }
.detail-type-mark { width: 16rpx; height: 16rpx; margin-right: 16rpx; }
.detail-type, .detail-product { display: block; }
.detail-type { font-size: 27rpx; font-weight: 700; }
.detail-product { max-width: 380rpx; margin-top: 5rpx; overflow: hidden; color: #59615C; font-size: 21rpx; text-overflow: ellipsis; white-space: nowrap; }
.detail-delta { margin-left: auto; font-size: 30rpx; font-weight: 700; white-space: nowrap; }
.detail-rows { border-top: 1rpx solid #E7EBE8; }
.detail-row { display: flex; align-items: flex-start; justify-content: space-between; gap: 28rpx; padding: 19rpx 2rpx; border-bottom: 1rpx solid #F0F2F0; }
.detail-label { flex-shrink: 0; color: #747A76; font-size: 23rpx; }
.detail-value { min-width: 0; color: #171917; font-size: 23rpx; text-align: right; word-break: break-all; }
.detail-value--accent { color: #078B4B; font-size: 26rpx; font-weight: 700; }
.detail-actions { padding-bottom: 18rpx; }
