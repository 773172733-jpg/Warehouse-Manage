<view class="profile-page">
  <view class="user-card" catchtap="openProfileModal">
    <view class="avatar" style="background-color: {{user.avatarColor}};">{{user.avatarText}}</view>
    <view class="user-main">
      <view class="user-line">
        <text class="user-name">{{user.name}}</text>
        <text class="self-badge">当前用户</text>
      </view>
      <text class="user-remark">团队备注：{{user.memberRemark}}</text>
      <view class="user-meta">
        <text class="role-badge role-badge--{{user.roleClass}}">{{user.roleLabel}}</text>
      </view>
    </view>
    <view class="arrow">›</view>
  </view>

  <view wx:if="{{permission.isViewer}}" class="readonly-note">普通成员视角以查看和个人偏好为主</view>

  <view class="section-card">
    <view class="section-head">
      <text class="section-title">当前团队</text>
      <text class="section-action {{hasTeam ? '' : 'section-action--disabled'}}" data-action="team" data-disabled="{{!hasTeam}}" catchtap="onQuickEntryTap">查看团队成员</text>
    </view>
    <view class="team-grid">
      <view class="team-item">
        <text class="team-label">当前团队</text>
        <text class="team-value">{{team.name}}</text>
      </view>
      <view class="team-item">
        <text class="team-label">当前仓库</text>
        <text class="team-value">{{team.warehouseName}}</text>
      </view>
      <view class="team-item">
        <text class="team-label">我的角色</text>
        <text class="team-value">{{user.roleLabel}}</text>
      </view>
    </view>
    <view wx:if="{{!hasTeam}}" class="empty-team-entry" data-action="joinTeam" catchtap="onQuickEntryTap">创建或加入团队</view>
  </view>

  <view class="section-block">
    <view class="block-title">常用入口</view>
    <view class="entry-list">
      <view wx:for="{{quickEntries}}" wx:key="key" class="entry-row {{item.disabled ? 'entry-row--disabled' : ''}}" data-action="{{item.action}}" data-disabled="{{item.disabled}}" catchtap="onQuickEntryTap">
        <view>
          <text class="entry-title">{{item.title}}</text>
          <text class="entry-desc">{{item.desc}}</text>
        </view>
        <text class="entry-arrow">›</text>
      </view>
    </view>
  </view>

  <view class="section-block">
    <view class="block-title">帮助与关于</view>
    <view class="entry-list">
      <view class="entry-row" data-modal="help" catchtap="openModalFromTap">
        <view><text class="entry-title">使用帮助</text><text class="entry-desc">查看口袋仓库Go基础使用说明</text></view>
        <text class="entry-arrow">›</text>
      </view>
      <view class="entry-row" data-modal="about" catchtap="openModalFromTap">
        <view><text class="entry-title">关于口袋仓库Go</text><text class="entry-desc">{{appInfo.version}}</text></view>
        <text class="entry-arrow">›</text>
      </view>
      <view class="entry-row" data-modal="privacy" catchtap="openModalFromTap">
        <view><text class="entry-title">隐私说明</text><text class="entry-desc">数据与图片使用说明</text></view>
        <text class="entry-arrow">›</text>
      </view>
      <view class="version-row">
        <text>当前版本</text>
        <text>{{appInfo.version}}</text>
      </view>
    </view>
  </view>

</view>

<view wx:if="{{modalOpen}}" class="sheet-mask" catchtap="closeModal" catchtouchmove="stopPropagation">
  <view class="bottom-sheet" catchtap="stopPropagation">
    <view class="sheet-handle"></view>
    <view class="sheet-header">
      <text class="sheet-title">{{modalTitle}}</text>
      <view class="sheet-close" catchtap="closeModal">×</view>
    </view>
    <scroll-view class="sheet-content" scroll-y>
      <view wx:if="{{activeModal === 'profile'}}" class="profile-detail">
        <view class="detail-head">
          <view class="detail-avatar" style="background-color: {{user.avatarColor}};">{{user.avatarText}}</view>
          <view>
            <text class="detail-name">{{user.name}}</text>
            <text class="detail-sub">{{user.roleLabel}} · {{user.memberRemark}}</text>
          </view>
        </view>
        <view class="detail-rows">
          <view class="detail-row"><text>姓名</text><text>{{user.name}}</text></view>
          <view class="detail-row"><text>团队备注</text><text>{{user.memberRemark}}</text></view>
          <view class="detail-row"><text>当前角色</text><text>{{user.roleLabel}}</text></view>
          <view class="detail-row"><text>加入时间</text><text>{{user.joinedAt}}</text></view>
        </view>
      </view>

      <view wx:elif="{{activeModal === 'about'}}" class="about-panel">
        <text class="about-name">{{appInfo.appName}}</text>
        <text class="about-desc">团队共享库存管理工具</text>
        <view class="detail-rows">
          <view class="detail-row"><text>版本</text><text>{{appInfo.version}}</text></view>
          <view class="detail-row"><text>用途</text><text>{{appInfo.buildLabel}}</text></view>
        </view>
      </view>

      <view wx:else class="plain-content">
        <view wx:for="{{modalParagraphs}}" wx:key="*this" class="modal-paragraph">{{item}}</view>
        <view wx:if="{{modalBullets.length}}" class="bullet-list">
          <view wx:for="{{modalBullets}}" wx:key="*this" class="bullet-row">
            <text class="bullet-dot"></text>
            <text>{{item}}</text>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>
</view>
