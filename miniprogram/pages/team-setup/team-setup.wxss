.setup-page {
  min-height: 100vh;
  padding: 64rpx 32rpx calc(48rpx + env(safe-area-inset-bottom));
  background: #F7F8F7;
  box-sizing: border-box;
}

.setup-header {
  padding: 12rpx 4rpx 36rpx;
}

.setup-title,
.setup-subtitle,
.field-label,
.form-error {
  display: block;
}

.setup-title {
  color: #171917;
  font-size: 48rpx;
  font-weight: 700;
}

.setup-subtitle {
  margin-top: 14rpx;
  color: #747A76;
  font-size: 26rpx;
  line-height: 1.5;
}

.setup-form {
  padding: 30rpx 28rpx;
  border: 1rpx solid #E7EBE8;
  border-radius: 16rpx;
  background: #FFFFFF;
}

.field-group + .field-group {
  margin-top: 28rpx;
}

.field-label {
  margin-bottom: 12rpx;
  color: #171917;
  font-size: 26rpx;
  font-weight: 600;
}

.field-input {
  height: 88rpx;
  padding: 0 22rpx;
  border: 1rpx solid #DDE3DF;
  border-radius: 12rpx;
  background: #FAFBFA;
  color: #171917;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-error {
  margin-top: 20rpx;
  color: #D94A45;
  font-size: 24rpx;
  line-height: 1.45;
}

.create-button {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 92rpx;
  margin-top: 32rpx;
  border-radius: 14rpx;
  background: #078B4B;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 92rpx;
}

.create-button::after {
  border: 0;
}

.create-button[disabled] {
  background: #8BBE9F;
  color: #FFFFFF;
}

.join-entry {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  min-height: 88rpx;
  margin-top: 24rpx;
  font-size: 25rpx;
}

.join-label {
  color: #747A76;
}

.join-action {
  color: #078B4B;
  font-weight: 600;
}
