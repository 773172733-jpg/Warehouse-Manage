.team-shell,
.team-page {
  min-height: 100vh;
  background: #F7F8F7;
}

.team-page {
  padding: 28rpx 28rpx calc(48rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  overflow-x: hidden;
}

.team-card,
.invite-card,
.pending-card,
.member-card {
  border: 1rpx solid #E7EBE8;
  border-radius: 16rpx;
  background: #FFFFFF;
}

.team-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 28rpx;
}

.team-card-main,
.member-main {
  min-width: 0;
  flex: 1;
}

.eyebrow,
.team-name,
.team-warehouse,
.section-title,
.section-desc,
.invite-label,
.invite-code,
.invite-empty-title,
.invite-empty-desc,
.inline-error,
.member-name,
.member-time,
.member-remark {
  display: block;
}

.eyebrow {
  color: #078B4B;
  font-size: 22rpx;
  font-weight: 600;
}

.team-name {
  margin-top: 8rpx;
  color: #171917;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.25;
  overflow-wrap: anywhere;
}

.team-warehouse {
  margin-top: 8rpx;
  color: #59615C;
  font-size: 26rpx;
}

.team-role-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}

.team-count {
  color: #747A76;
  font-size: 22rpx;
}

.team-avatar,
.member-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: none;
  color: #FFFFFF;
  font-weight: 700;
}

.team-avatar {
  width: 104rpx;
  height: 104rpx;
  border-radius: 20rpx;
  background: #078B4B;
  font-size: 42rpx;
}

.readonly-note {
  margin-top: 16rpx;
  padding: 18rpx 22rpx;
  border: 1rpx solid #E7EBE8;
  border-radius: 12rpx;
  background: #FFFFFF;
  color: #747A76;
  font-size: 23rpx;
  line-height: 1.55;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 20rpx;
}

.stats-grid--owner {
  grid-template-columns: repeat(4, minmax(0, 1fr));
}

.stat-item {
  min-width: 0;
  padding: 22rpx 8rpx;
  border: 1rpx solid #E7EBE8;
  border-radius: 14rpx;
  background: #FFFFFF;
  text-align: center;
}

.stat-item--pending {
  background: #FFF8EC;
}

.stat-value,
.stat-label {
  display: block;
}

.stat-value {
  color: #171917;
  font-size: 34rpx;
  font-weight: 700;
}

.stat-label {
  margin-top: 6rpx;
  color: #747A76;
  font-size: 20rpx;
  white-space: nowrap;
}

.section-block {
  margin-top: 36rpx;
}

.section-header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  padding: 0 4rpx 16rpx;
}

.section-title {
  color: #171917;
  font-size: 30rpx;
  font-weight: 700;
}

.section-desc {
  margin-top: 6rpx;
  color: #747A76;
  font-size: 22rpx;
}

.invite-card {
  padding: 28rpx;
}

.invite-loading,
.invite-empty {
  padding: 34rpx 0;
  text-align: center;
}

.invite-loading,
.invite-empty-desc {
  color: #747A76;
  font-size: 24rpx;
}

.invite-empty-title {
  color: #171917;
  font-size: 28rpx;
  font-weight: 600;
}

.invite-empty-desc {
  margin-top: 10rpx;
  line-height: 1.5;
}

.invite-code-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.invite-label {
  color: #747A76;
  font-size: 22rpx;
}

.invite-code {
  margin-top: 6rpx;
  color: #06713E;
  font-size: 46rpx;
  font-weight: 700;
  letter-spacing: 0;
}

.icon-command {
  min-width: 104rpx;
  height: 64rpx;
  margin: 0;
  padding: 0 20rpx;
  border: 1rpx solid #078B4B;
  border-radius: 12rpx;
  background: #FFFFFF;
  color: #078B4B;
  font-size: 24rpx;
  line-height: 62rpx;
}

.icon-command::after,
.primary-button::after,
.review-button::after,
.search-clear::after,
.text-button::after {
  border: 0;
}

.invite-details {
  margin-top: 24rpx;
  border-top: 1rpx solid #E7EBE8;
}

.invite-detail {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  min-height: 68rpx;
  border-bottom: 1rpx solid #F0F2F1;
  color: #747A76;
  font-size: 23rpx;
}

.invite-detail text:last-child {
  color: #171917;
  font-weight: 600;
  text-align: right;
}

.inline-error {
  margin-top: 18rpx;
  color: #D94A45;
  font-size: 23rpx;
  line-height: 1.5;
}

.primary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 82rpx;
  margin-top: 24rpx;
  border-radius: 14rpx;
  background: #078B4B;
  color: #FFFFFF;
  font-size: 27rpx;
  font-weight: 600;
  line-height: 82rpx;
}

.primary-button[disabled] {
  background: #8BBE9F;
  color: #FFFFFF;
}

.pending-list,
.member-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.pending-card {
  padding: 24rpx;
}

.member-summary,
.member-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.member-avatar {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  font-size: 28rpx;
}

.member-name-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
}

.member-name {
  min-width: 0;
  color: #171917;
  font-size: 27rpx;
  font-weight: 600;
  overflow-wrap: anywhere;
}

.member-time,
.member-remark {
  margin-top: 8rpx;
  color: #747A76;
  font-size: 22rpx;
  line-height: 1.4;
}

.role-badge,
.status-badge,
.self-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 36rpx;
  padding: 0 12rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  line-height: 1.2;
  box-sizing: border-box;
}

.role-badge--owner {
  background: #EAF6EF;
  color: #06713E;
}

.role-badge--admin {
  background: #EAF1F7;
  color: #35637D;
}

.role-badge--viewer,
.role-badge--unknown {
  background: #F0F2F1;
  color: #59615C;
}

.status-badge--pending {
  background: #FFF3DF;
  color: #B56D08;
}

.self-badge {
  background: #EAF6EF;
  color: #078B4B;
}

.review-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 22rpx;
}

.review-button {
  height: 70rpx;
  margin: 0;
  border-radius: 12rpx;
  font-size: 25rpx;
  line-height: 70rpx;
}

.review-button--reject {
  border: 1rpx solid #D94A45;
  background: #FFFFFF;
  color: #D94A45;
}

.review-button--approve {
  background: #078B4B;
  color: #FFFFFF;
}

.review-button[disabled] {
  opacity: 0.55;
}

.search-box {
  display: flex;
  align-items: center;
  height: 82rpx;
  padding: 0 12rpx 0 22rpx;
  border: 1rpx solid #E7EBE8;
  border-radius: 14rpx;
  background: #FFFFFF;
  box-sizing: border-box;
}

.search-icon {
  position: relative;
  width: 28rpx;
  height: 28rpx;
  margin-right: 14rpx;
  border: 3rpx solid #8A928D;
  border-radius: 50%;
  box-sizing: border-box;
}

.search-icon::after {
  position: absolute;
  right: -10rpx;
  bottom: -7rpx;
  width: 12rpx;
  height: 3rpx;
  background: #8A928D;
  content: '';
  transform: rotate(45deg);
}

.search-input {
  flex: 1;
  min-width: 0;
  height: 80rpx;
  color: #171917;
  font-size: 25rpx;
}

.search-clear {
  width: 58rpx;
  height: 58rpx;
  margin: 0;
  padding: 0;
  background: transparent;
  color: #747A76;
  font-size: 36rpx;
  line-height: 58rpx;
}

.role-scroll {
  width: 100%;
  margin-top: 16rpx;
  white-space: nowrap;
}

.role-row {
  display: inline-flex;
  gap: 12rpx;
  padding-bottom: 2rpx;
}

.role-chip {
  min-width: 92rpx;
  height: 58rpx;
  padding: 0 20rpx;
  border: 1rpx solid #E7EBE8;
  border-radius: 12rpx;
  background: #FFFFFF;
  color: #59615C;
  font-size: 23rpx;
  line-height: 58rpx;
  text-align: center;
  box-sizing: border-box;
}

.role-chip--active {
  border-color: #078B4B;
  background: #EAF6EF;
  color: #06713E;
  font-weight: 600;
}

.result-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 64rpx;
  color: #747A76;
  font-size: 22rpx;
}

.clear-filter {
  color: #078B4B;
  font-weight: 600;
}

.member-card {
  padding: 22rpx 24rpx;
}

.member-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 12rpx;
}

.member-meta .member-time {
  margin-top: 0;
}

.members-empty {
  text-align: center;
}

.text-button {
  height: 72rpx;
  margin-top: -24rpx;
  background: transparent;
  color: #078B4B;
  font-size: 24rpx;
  line-height: 72rpx;
}
