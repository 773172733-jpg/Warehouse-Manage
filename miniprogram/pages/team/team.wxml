<view class="team-shell">
  <app-loading wx:if="{{pageStatus === 'loading'}}" text="正在加载团队数据"></app-loading>

  <error-state
    wx:elif="{{pageStatus === 'error'}}"
    title="团队数据加载失败"
    message="{{errorMessage}}"
    bind:retry="handleRetry"
  ></error-state>

  <view wx:else class="team-page">
    <view class="team-card">
      <view class="team-card-main">
        <text class="eyebrow">当前团队</text>
        <text class="team-name">{{team.name}}</text>
        <text class="team-warehouse">{{team.warehouseName}}</text>
        <view class="team-role-row">
          <text class="role-badge role-badge--{{currentRole}}">{{team.roleLabel}}</text>
          <text class="team-count">{{stats.all}} 位已加入成员</text>
        </view>
      </view>
      <view class="team-avatar">轻</view>
    </view>

    <view wx:if="{{permission.canSeeReadonlyNotice}}" class="readonly-note">
      当前角色可查看真实成员，邀请码和入队审核仅由团队创建者管理。
    </view>

    <view class="stats-grid {{permission.isOwner ? 'stats-grid--owner' : ''}}">
      <view class="stat-item">
        <text class="stat-value">{{stats.owner}}</text>
        <text class="stat-label">创建者</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{stats.admin}}</text>
        <text class="stat-label">管理员</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{stats.viewer}}</text>
        <text class="stat-label">普通成员</text>
      </view>
      <view wx:if="{{permission.isOwner}}" class="stat-item stat-item--pending">
        <text class="stat-value">{{stats.pending}}</text>
        <text class="stat-label">待审核</text>
      </view>
    </view>

    <view wx:if="{{permission.canManageInvites}}" class="section-block">
      <view class="section-header">
        <view>
          <text class="section-title">团队邀请码</text>
          <text class="section-desc">申请人提交后需要由你审核</text>
        </view>
      </view>

      <view class="invite-card">
        <view wx:if="{{inviteLoading}}" class="invite-loading">正在读取真实邀请码</view>

        <block wx:elif="{{invite.hasInvite}}">
          <view class="invite-code-row">
            <view>
              <text class="invite-label">当前邀请码</text>
              <text class="invite-code">{{invite.code}}</text>
            </view>
            <button class="icon-command" aria-label="复制邀请码" bindtap="copyInviteCode">复制</button>
          </view>
          <view class="invite-details">
            <view class="invite-detail"><text>到期时间</text><text>{{invite.expiresAtText}}</text></view>
            <view class="invite-detail"><text>使用次数</text><text>{{invite.usedCount}} / {{invite.maxUses}}</text></view>
            <view class="invite-detail"><text>剩余次数</text><text>{{invite.remainingUses}}</text></view>
            <view class="invite-detail"><text>加入方式</text><text>{{invite.approvalLabel}}</text></view>
          </view>
        </block>

        <view wx:else class="invite-empty">
          <text class="invite-empty-title">当前没有可用邀请码</text>
          <text class="invite-empty-desc">生成后可复制给需要加入团队的成员</text>
        </view>

        <text wx:if="{{inviteError}}" class="inline-error">{{inviteError}}</text>
        <button
          class="primary-button"
          loading="{{inviteRefreshing}}"
          disabled="{{inviteRefreshing}}"
          bindtap="handleInviteAction"
        >{{inviteRefreshing ? '正在处理' : (invite.hasInvite ? '刷新邀请码' : '生成邀请码')}}</button>
      </view>
    </view>

    <view wx:if="{{permission.canViewPending}}" class="section-block">
      <view class="section-header">
        <view>
          <text class="section-title">待审核申请</text>
          <text class="section-desc">{{pendingMembers.length}} 条真实入队申请</text>
        </view>
      </view>

      <view wx:if="{{pendingMembers.length}}" class="pending-list">
        <view wx:for="{{pendingMembers}}" wx:key="id" class="pending-card">
          <view class="member-summary">
            <image class="member-avatar pixel-image" src="{{item.avatarPath}}" mode="aspectFill"></image>
            <view class="member-main">
              <view class="member-name-row">
                <text class="member-name">{{item.name}}</text>
                <text class="status-badge status-badge--pending">待审核</text>
              </view>
              <text class="member-time">申请时间 {{item.appliedAtText}}</text>
            </view>
          </view>
          <view class="review-actions">
            <button
              class="review-button review-button--reject"
              data-id="{{item.id}}"
              data-decision="reject"
              disabled="{{reviewingMemberId}}"
              bindtap="handleReview"
            >拒绝</button>
            <button
              class="review-button review-button--approve"
              data-id="{{item.id}}"
              data-decision="approve"
              loading="{{reviewingMemberId === item.id}}"
              disabled="{{reviewingMemberId}}"
              bindtap="handleReview"
            >同意</button>
          </view>
        </view>
      </view>

      <empty-state
        wx:else
        title="暂无待审核申请"
        description="有成员提交真实邀请码后会显示在这里"
      ></empty-state>
    </view>

    <view class="section-block members-section">
      <view class="section-header">
        <view>
          <text class="section-title">团队成员</text>
          <text class="section-desc">真实 active 成员</text>
        </view>
      </view>

      <view class="search-box">
        <view class="search-icon"></view>
        <input
          class="search-input"
          value="{{keyword}}"
          placeholder="{{permission.canManageAdminNotes ? '搜索团队昵称或管理备注' : '搜索团队昵称'}}"
          confirm-type="search"
          bindinput="onSearchInput"
        />
        <button wx:if="{{keyword}}" class="search-clear" aria-label="清除搜索" bindtap="clearSearch">×</button>
      </view>

      <scroll-view class="role-scroll" scroll-x enhanced show-scrollbar="{{false}}">
        <view class="role-row">
          <view
            wx:for="{{roleOptions}}"
            wx:key="value"
            class="role-chip {{activeRole === item.value ? 'role-chip--active' : ''}}"
            data-role="{{item.value}}"
            bindtap="onRoleTap"
          >{{item.label}}</view>
        </view>
      </scroll-view>

      <view class="result-row">
        <text>{{filteredMembers.length}} 位成员</text>
        <text wx:if="{{keyword || activeRole !== 'all'}}" class="clear-filter" bindtap="clearFilters">清除筛选</text>
      </view>

      <view wx:if="{{filteredMembers.length}}" class="member-list">
        <view
          wx:for="{{filteredMembers}}"
          wx:key="id"
          class="member-card member-card--interactive"
          data-id="{{item.id}}"
          hover-class="member-card--pressed"
          bindtap="handleMemberTap"
        >
          <image class="member-avatar pixel-image" src="{{item.avatarPath}}" mode="aspectFill"></image>
          <view class="member-main">
            <view class="member-name-row">
              <text class="member-name">{{item.name}}</text>
              <text wx:if="{{item.isCurrentUser}}" class="self-badge">我</text>
            </view>
            <text wx:if="{{permission.canManageAdminNotes}}" class="member-remark">管理备注：{{item.adminNote || '未填写'}}</text>
            <view class="member-meta">
              <text class="role-badge role-badge--{{item.roleClass}}">{{item.roleLabel}}</text>
              <text class="member-time">加入 {{item.joinedAtText}}</text>
            </view>
          </view>
        </view>
      </view>

      <view wx:else class="members-empty">
        <empty-state
          title="{{activeMembers.length ? '没有符合条件的成员' : '暂无团队成员'}}"
          description="{{activeMembers.length ? '尝试修改关键词或角色筛选' : '真实成员加入后会显示在这里'}}"
        ></empty-state>
        <button wx:if="{{activeMembers.length}}" class="text-button" bindtap="clearFilters">清除筛选</button>
      </view>
    </view>

    <view class="section-block danger-section">
      <view class="section-header">
        <view>
          <text class="section-title">团队身份</text>
          <text class="section-desc">团队关系变更后将重新核验身份</text>
        </view>
      </view>
      <view class="danger-card">
        <text wx:if="{{permission.isOwner}}" class="owner-leave-note">
          团队创建者暂不支持退出团队
        </text>
        <button
          wx:elif="{{permission.canLeaveTeam}}"
          class="danger-outline-button"
          loading="{{leaving}}"
          disabled="{{leaving}}"
          bindtap="handleLeaveTeam"
        >{{leaving ? '正在退出' : '退出团队'}}</button>
      </view>
    </view>
  </view>

  <view
    wx:if="{{memberSheetOpen && selectedMember}}"
    class="member-sheet-mask"
    bindtap="closeMemberSheet"
  >
    <view class="member-sheet" catchtap="stopPropagation">
      <view class="sheet-handle"></view>
      <view class="sheet-header">
        <text class="sheet-title">成员详情</text>
        <button
          class="sheet-close"
          aria-label="关闭成员详情"
          disabled="{{memberOperation.memberId}}"
          bindtap="closeMemberSheet"
        >×</button>
      </view>

      <view class="sheet-member">
        <image
          class="member-avatar member-avatar--large pixel-image"
          src="{{selectedMember.avatarPath}}"
          mode="aspectFill"
        ></image>
        <view class="sheet-member-main">
          <view class="member-name-row">
            <text class="sheet-member-name">{{selectedMember.name}}</text>
            <text wx:if="{{selectedMember.isCurrentUser}}" class="self-badge">我</text>
          </view>
          <text class="role-badge role-badge--{{selectedMember.roleClass}}">
            {{selectedMember.roleLabel}}
          </text>
        </view>
      </view>

      <view class="sheet-details">
        <view class="sheet-detail-row">
          <text>加入时间</text>
          <text>{{selectedMember.joinedAtText}}</text>
        </view>
        <view class="sheet-detail-row">
          <text>当前身份</text>
          <text>{{selectedMember.isCurrentUser ? '当前用户' : '团队成员'}}</text>
        </view>
        <view wx:if="{{permission.canManageAdminNotes && selectedMember.hasAdminNoteAccess}}" class="sheet-detail-row">
          <text>管理备注</text>
          <text>{{selectedMember.adminNote || '未填写'}}</text>
        </view>
      </view>

      <text class="role-description">{{selectedMember.roleDescription}}</text>

      <view wx:if="{{selectedMember.isOwnerSelf}}" class="owner-sheet-note">
        团队创建者暂不支持转让或退出团队
      </view>

      <view
        wx:if="{{selectedMember.canEditAdminNote || selectedMember.canChangeRole || selectedMember.canRemove}}"
        class="member-action-list"
      >
        <button
          wx:if="{{selectedMember.canEditAdminNote}}"
          class="member-action-button member-action-button--secondary"
          disabled="{{memberOperation.memberId || noteSaving}}"
          bindtap="openAdminNoteEditor"
        >编辑管理备注</button>
        <button
          wx:if="{{selectedMember.canChangeRole}}"
          class="member-action-button member-action-button--primary"
          loading="{{memberOperation.memberId === selectedMember.id && memberOperation.action === 'role'}}"
          disabled="{{memberOperation.memberId}}"
          bindtap="handleMemberRoleAction"
        >{{selectedMember.roleActionLabel}}</button>
        <button
          wx:if="{{selectedMember.canRemove}}"
          class="member-action-button member-action-button--danger"
          loading="{{memberOperation.memberId === selectedMember.id && memberOperation.action === 'remove'}}"
          disabled="{{memberOperation.memberId}}"
          bindtap="handleRemoveMember"
        >移出团队</button>
      </view>
    </view>
  </view>

  <view wx:if="{{noteEditorOpen && selectedMember}}" class="member-sheet-mask note-editor-mask" bindtap="closeAdminNoteEditor">
    <view class="member-sheet note-editor" catchtap="stopPropagation">
      <view class="sheet-handle"></view>
      <view class="sheet-header">
        <text class="sheet-title">管理备注</text>
        <button class="sheet-close" aria-label="关闭管理备注" disabled="{{noteSaving}}" bindtap="closeAdminNoteEditor">×</button>
      </view>
      <text class="note-target">仅创建者和管理员可见 · {{selectedMember.name}}</text>
      <textarea
        class="note-input"
        maxlength="40"
        value="{{draftAdminNote}}"
        placeholder="填写岗位、负责区域等内部备注，留空可清除"
        disabled="{{noteSaving}}"
        bindinput="onAdminNoteInput"
      ></textarea>
      <view class="note-actions">
        <button class="member-action-button member-action-button--secondary" disabled="{{noteSaving}}" bindtap="closeAdminNoteEditor">取消</button>
        <button class="member-action-button member-action-button--primary" loading="{{noteSaving}}" disabled="{{noteSaving}}" bindtap="saveAdminNote">保存</button>
      </view>
    </view>
  </view>
</view>
