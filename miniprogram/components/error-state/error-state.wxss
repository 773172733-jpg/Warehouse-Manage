.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 360rpx;
  padding: 32rpx;
  text-align: center;
}

.error-mark {
  width: 88rpx;
  height: 88rpx;
  margin-bottom: 24rpx;
  border-radius: 50%;
  background: #FDE7E2;
  color: #B42318;
  font-size: 48rpx;
  line-height: 88rpx;
  font-weight: 700;
}

.error-title {
  margin-bottom: 12rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #1F2A24;
}

.error-message {
  margin-bottom: 28rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #647067;
}

.retry-button {
  min-width: 180rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 8rpx;
  background: #078B4B;
  color: #FFFFFF;
  font-size: 28rpx;
}
