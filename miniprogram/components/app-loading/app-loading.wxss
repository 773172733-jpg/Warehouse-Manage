.app-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 320rpx;
  color: #647067;
}

.spinner {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 20rpx;
  border: 6rpx solid #DCE4DE;
  border-top-color: #078B4B;
  border-radius: 50%;
  animation: spin 0.9s linear infinite;
}

.loading-text {
  font-size: 28rpx;
}

@keyframes spin {
  from {
    transform: rotate(0deg);
  }

  to {
    transform: rotate(360deg);
  }
}
