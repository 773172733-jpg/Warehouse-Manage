page {
  min-height: 100%;
  background: #F7F8F7;
  color: #1F2A24;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 32rpx;
  background: #F7F8F7;
}

.placeholder-title {
  margin: 0 0 16rpx;
  font-size: 40rpx;
  font-weight: 600;
  color: #1F2A24;
}

.placeholder-text {
  margin: 0;
  font-size: 28rpx;
  line-height: 1.7;
  color: #647067;
}

.placeholder-panel {
  padding: 32rpx;
  background: #FFFFFF;
  border: 1rpx solid #E4E8E5;
  border-radius: 8rpx;
}
